{
  "extends": "@testspectra/tsconfig/tsconfig.json",
  "ts-node": {
    "transpileOnly": true
  },
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "build",
    "checkJs": true,
    "types": ["mocha", "chai", "chai-as-promised", "node"],
    "paths": {
      "@testspectra/types": ["../types"],
      "@testspectra/appium/support": ["../appium/support"],
      "@testspectra/appium/driver": ["../appium/driver"],
      "@testspectra/driver-test-support": ["../driver-test-support"]
    }
  },
  "include": ["lib", "test"],
  "references": [
    {"path": "../types"},
    {"path": "../support"},
    {"path": "../driver-test-support"},
    {"path": "../base-driver"}
  ]
}
